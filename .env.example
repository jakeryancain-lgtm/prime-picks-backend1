# ─────────────────────────────────────────────────────────────────────────────
# Prime Picks — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# .env is already in .gitignore — keep it that way.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Your Supabase project URL. Find it under: Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase service role key. Find it under: Project Settings → API → service_role (secret).
# This key bypasses Row Level Security. Do not expose it client-side or in browser code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Engine configuration (optional — defaults shown) ─────────────────────────
# Minimum edge required for a pick to qualify (decimal, e.g. 0.03 = 3%)
MIN_EDGE_THRESHOLD=0.03

# American odds limit — picks worse than this are tagged BAD_ODDS_RANGE (e.g. -170)
MAX_NEGATIVE_ODDS=-170

# Maximum picks in the Top N output
MAX_TOP_PICKS=5

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=development
